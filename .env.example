# Local development defaults
PORT=3001
HOST=127.0.0.1
HARDWARE_FLOW_STORE_PATH=./data/demo-store.json
HARDWARE_FLOW_ACCESS_LOG=1
HARDWARE_FLOW_MAX_JSON_BODY_BYTES=1048576
HARDWARE_FLOW_REQUEST_TIMEOUT_MS=120000
# Startup read source: json, postgres, or postgres-fallback.
HARDWARE_FLOW_STARTUP_STORE_SOURCE=json
# Runtime mutation policy: auto, read-write, or read-only. Auto makes PostgreSQL snapshots read-only.
HARDWARE_FLOW_RUNTIME_WRITE_MODE=auto
# Runtime persistence backend: json or postgres-mirror. Mirror mode verifies every write and rolls back JSON on failure.
HARDWARE_FLOW_RUNTIME_PERSISTENCE_BACKEND=json
# SQL/report workspace used by postgres-mirror runtime persistence.
HARDWARE_FLOW_RUNTIME_POSTGRES_SYNC_DIR=./data/runtime-postgres-sync
# Optional project selected when loading the PostgreSQL startup snapshot.
HARDWARE_FLOW_POSTGRES_ACTIVE_PROJECT_ID=
# Required when the startup source uses PostgreSQL.
DATABASE_URL=
# Optional. When set, API data routes require x-pilot-access-code.
HARDWARE_FLOW_PILOT_ACCESS_CODE=
