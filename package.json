{
  "name": "human-agent-hardware-flow",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "node apps/api/src/server.mjs",
    "start": "node apps/api/src/server.mjs",
    "start:lan": "HOST=0.0.0.0 node apps/api/src/server.mjs",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "check": "npm test && npm run smoke && npm run db:export-rows -- /tmp/hardware-flow-postgres-rows.json",
    "test": "node --test apps/api/src/*.test.mjs",
    "smoke": "node apps/api/src/smoke.mjs",
    "demo": "node apps/api/src/demo.mjs",
    "demo:multi-phase": "node apps/api/src/multiPhaseDemo.mjs",
    "db:export-rows": "node apps/api/src/exportPostgresRows.mjs",
    "agent:sample": "python3 agents/worker/worker.py"
  }
}
