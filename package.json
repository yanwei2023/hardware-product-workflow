{
  "name": "human-agent-hardware-flow",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "node apps/api/src/server.mjs",
    "start": "node apps/api/src/server.mjs",
    "start:lan": "HOST=0.0.0.0 node apps/api/src/server.mjs",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "check": "npm test && npm run web:build && npm run smoke && npm run store:doctor && npm run db:migration-check && npm run db:schema-check && npm run db:export-report && npm run db:export-rows -- /tmp/hardware-flow-postgres-rows.json && npm run db:restore-store -- /tmp/hardware-flow-postgres-rows.json --output /tmp/hardware-flow-postgres-restored-store.json --confirm && npm run store:doctor -- /tmp/hardware-flow-postgres-restored-store.json && npm run store:runtime-check -- /tmp/hardware-flow-postgres-restored-store.json && npm run db:export-seed -- /tmp/hardware-flow-postgres-seed.sql && npm run db:prepare-import -- /tmp/hardware-flow-postgres-import && npm run db:verify-import-bundle -- /tmp/hardware-flow-postgres-import",
    "release:check": "npm run check && git diff --check",
    "pilot:check": "npm run release:check && npm run pilot:rehearse && npm run pilot:archive -- /tmp/hardware-flow-pilot-archive && npm run db:preflight -- /tmp/hardware-flow-postgres-import",
    "test": "node --test apps/api/src/*.test.mjs",
    "smoke": "node apps/api/src/smoke.mjs",
    "store:doctor": "node apps/api/src/storeDoctor.mjs",
    "store:runtime-check": "node apps/api/src/verifyStoreRuntime.mjs",
    "store:restore-backup": "node apps/api/src/restoreStoreBackup.mjs",
    "demo": "node apps/api/src/demo.mjs",
    "demo:multi-phase": "node apps/api/src/multiPhaseDemo.mjs",
    "web:build": "npm --workspace apps/web run build",
    "db:migration-check": "node apps/api/src/postgresMigrationCheck.mjs",
    "db:export-rows": "node apps/api/src/exportPostgresRows.mjs",
    "db:export-seed": "node apps/api/src/exportPostgresSeed.mjs",
    "db:export-report": "node apps/api/src/exportPostgresReport.mjs",
    "db:prepare-import": "node apps/api/src/preparePostgresImport.mjs",
    "db:verify-import-bundle": "node apps/api/src/verifyPostgresImportBundle.mjs",
    "db:import": "node apps/api/src/postgresImportCli.mjs",
    "db:verify-import-result": "node apps/api/src/verifyPostgresImportResult.mjs",
    "db:restore-store": "node apps/api/src/restoreStoreFromPostgresRows.mjs",
    "db:export-live-rows": "node apps/api/src/exportPostgresDatabaseRows.mjs",
    "db:pull-store": "node apps/api/src/pullStoreFromPostgres.mjs",
    "db:compare-store": "node apps/api/src/compareStoreWithPostgres.mjs",
    "db:verify-store-comparison": "node apps/api/src/verifyPostgresStoreComparison.mjs",
    "db:preflight": "node apps/api/src/postgresPreflightCli.mjs",
    "db:schema-check": "node apps/api/src/postgresSchemaCheck.mjs",
    "pilot:archive": "node apps/api/src/preparePilotArchive.mjs",
    "pilot:rehearse": "node apps/api/src/pilotRehearsal.mjs",
    "agent:sample": "python3 agents/worker/worker.py",
    "demo:enrich": "node apps/api/src/enrichDemoStore.mjs"
  }
}
